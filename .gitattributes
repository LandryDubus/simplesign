# Ensure shell scripts always use LF line endings (required for Linux containers)
*.sh text eol=lf

# Ensure C# source files always use LF (required by .editorconfig for IDE0055)
*.cs text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.sln text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf
