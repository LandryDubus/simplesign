<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>SimpleSign.PAdES</AssemblyName>
    <RootNamespace>SimpleSign.PAdES</RootNamespace>
    <PackageId>SimpleSign.PAdES</PackageId>
    <Description>Sign, validate, and inspect PDF digital signatures (PAdES ETSI EN 319 142). Supports B-B, B-T, B-LT, B-LTA conformance levels. Fluent async API. No BouncyCastle — uses only System.Security.Cryptography. Native AOT compatible.</Description>
    <Version>0.3.0</Version>
    <IsAotCompatible Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net9.0'))">true</IsAotCompatible>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SimpleSign.Core\SimpleSign.Core.csproj" />
    <ProjectReference Include="..\SimpleSign.Pdf\SimpleSign.Pdf.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="SimpleSign.Brasil" />
    <InternalsVisibleTo Include="SimpleSign.PAdES.Tests" />
    <InternalsVisibleTo Include="SimpleSign.Brasil.Tests" />
    <InternalsVisibleTo Include="SimpleSign.Fuzz" />
    <InternalsVisibleTo Include="simplesign" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="QRCoder" Version="1.8.0" />
  </ItemGroup>

</Project>

